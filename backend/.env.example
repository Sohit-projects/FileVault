# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI
# JWT
JWT_SECRET
JWT_EXPIRES_IN
JWT_REFRESH_SECRET
JWT_REFRESH_EXPIRES_IN

# Email (Nodemailer - Gmail example)
EMAIL_HOST
EMAIL_PORT
EMAIL_USER
EMAIL_PASS
