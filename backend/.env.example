# Google OAuth
GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET

# Cloudinary
CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET

# App
FRONTEND_URL=http://localhost:3000
MAX_FILE_SIZE_MB
MAX_STORAGE_GB
